APP_ENV=dev
STORE_BACKEND=sqlite
SQLITE_PATH=/tmp/cloudguard.db
AGENT_MEMORY_SQLITE_PATH=/tmp/agent_memory.db

CORRELATION_WINDOW_SECONDS=300
BRUTE_FORCE_THRESHOLD=8
EXFIL_BYTES_THRESHOLD=52428800
RESOURCE_HIJACK_THRESHOLD=10
OFFHOURS_START=20
OFFHOURS_END=6
ALERT_MIN_RISK=45

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LANGCHAIN_VERBOSE=false
